<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  data-provider-thread-count controls the number of parallel scenario threads.
  Driver and WebDriverFactory are ThreadLocal-safe. Increase to 4+ once your
  downstream project is verified thread-safe (PageManager and APIManager are
  singletons — ensure scenarios do not share page/API state across threads).
-->
<suite name="Sentinel Test Suite" verbose="1" data-provider-thread-count="1">
    <listeners>
        <listener class-name="listeners.RetryTransformer"/>
    </listeners>
    <test name="Cucumber Tests">
        <classes>
            <class name="tests.TestNGSentinelTests"/>
        </classes>
    </test>
</suite>
