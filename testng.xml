<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  data-provider-thread-count controls the number of parallel scenario threads.
  All shared state is ThreadLocal-isolated: Driver, WebDriverFactory, PageManager,
  APIManager, FileManager, DownloadManager, and ImageVerificationSteps.
-->
<suite name="Sentinel Test Suite" verbose="1" data-provider-thread-count="4">
    <listeners>
        <listener class-name="listeners.RetryTransformer"/>
    </listeners>
    <test name="Cucumber Tests">
        <classes>
            <class name="tests.TestNGSentinelTests"/>
        </classes>
    </test>
</suite>
